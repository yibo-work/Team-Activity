<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.dao.ActivityUserDao">
    <select id="findById" resultType="com.model.ActivityUser">
        select `id`, `activity_id`, `user_id`
        from activity_user
        where id = #{id}
    </select>

    <select id="findByMap" resultType="com.model.ActivityUser">
        select `id`,`activity_id`,`user_id` from activity_user
        <where>
            <if test="id != null and id != ''">
                and id = #{id}
            </if>
            <if test="activityId != null and activityId != ''">
                and activity_id = #{activityId}
            </if>
            <if test="userId != null and userId != ''">
                and user_id = #{userId}
            </if>
        </where>
    </select>

    <select id="list" resultType="com.model.ActivityUser">
        select `id`,`activity_id`,`user_id` from activity_user
        <where>
            <if test="id != null and id != ''">
                and id =
                #{id}
            </if>
            <if test="activityId != null and activityId != ''">
                and activity_id =
                #{activityId}
            </if>
            <if test="userId != null and userId != ''">
                and user_id =
                #{userId}
            </if>
        </where>
    </select>

    <insert id="save" parameterType="com.model.ActivityUser" useGeneratedKeys="true" keyProperty="id">
        insert into activity_user(
        <trim suffixOverrides=",">
            <if test="activityId != null">
                `activity_id`,
            </if>
            <if test="userId != null">
                `user_id`
            </if>
        </trim>
        )
        values (
        <trim suffixOverrides=",">
            <if test="activityId != null">
                #{activityId},
            </if>
            <if test="userId != null">
                #{userId}
            </if>
        </trim>
        )
    </insert>

    <update id="update" parameterType="com.model.ActivityUser">
        update activity_user
        <set>
            <if test="activityId != null">
                `activity_id` = #{activityId}
                ,
            </if>
            <if test="userId != null">
                `user_id` = #{userId}
            </if>
        </set>
        where id = #{id}
    </update>

    <delete id="deleteById">
        delete
        from activity_user
        where id = #{id}
    </delete>
</mapper>