<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.dao.ActivityDao">
    <select id="findById" resultType="com.model.Activity">
        select a.`id`,
               `team_id`,
               s.name as team_name,
               a.`name`,
               `content`,
               `start_time`,
               `budget`,
               `avg_budget`,
               `amount`,
               `avg_fee`,
               `end_time`
        from activity a
                     left join team s ON s.id = a.team_id
        where a.id = #{id}
    </select>

    <select id="findByMap" resultType="com.model.Activity">
        select a.`id`,
        `team_id`,
        s.name as team_name,
        a.`name`,
        `content`,
        `start_time`,
        `budget`,
        `avg_budget`,
        `amount`,
        `avg_fee`,
        `end_time`
        from activity a left join team s ON s.id = a.team_id
        <where>
            <if test="id != null and id != ''">
                and a.id = #{id}
            </if>
            <if test="teamId != null and teamId != ''">
                and team_id = #{teamId}
            </if>
            <if test="name != null and name != ''">
                and a.name = #{name}
            </if>
            <if test="content != null and content != ''">
                and content = #{content}
            </if>
            <if test="startTime != null and startTime != ''">
                and start_time = #{startTime}
            </if>
            <if test="budget != null and budget != ''">
                and budget = #{budget}
            </if>
            <if test="avgBudget != null and avgBudget != ''">
                and avg_budget = #{avgBudget}
            </if>
            <if test="amount != null and amount != ''">
                and amount = #{amount}
            </if>
            <if test="avgFee != null and avgFee != ''">
                and avg_fee = #{avgFee}
            </if>
            <if test="endTime != null and endTime != ''">
                and end_time = #{endTime}
            </if>
        </where>
    </select>

    <select id="list" resultType="com.model.Activity">
        select a.`id`,
        `team_id`,
        s.name as team_name,
        a.`name`,
        `content`,
        `start_time`,
        `budget`,
        `avg_budget`,
        `amount`,
        `avg_fee`,
        `end_time`
        from activity a left join team s ON s.id = a.team_id
        <where>
            <if test="id != null and id != ''">
                and a.id =
                #{id}
            </if>
            <if test="teamId != null and teamId != ''">
                and team_id =
                #{teamId}
            </if>
            <if test="name != null and name != ''">
                and a.name =
                #{name}
            </if>
            <if test="content != null and content != ''">
                and content =
                #{content}
            </if>
            <if test="startTime != null and startTime != ''">
                and start_time =
                #{startTime}
            </if>
            <if test="budget != null and budget != ''">
                and budget =
                #{budget}
            </if>
            <if test="avgBudget != null and avgBudget != ''">
                and avg_budget =
                #{avgBudget}
            </if>
            <if test="amount != null and amount != ''">
                and amount =
                #{amount}
            </if>
            <if test="avgFee != null and avgFee != ''">
                and avg_fee =
                #{avgFee}
            </if>
            <if test="endTime != null and endTime != ''">
                and end_time =
                #{endTime}
            </if>
        </where>
    </select>

    <insert id="save" parameterType="com.model.Activity" useGeneratedKeys="true" keyProperty="id">
        insert into activity(
        <trim suffixOverrides=",">
            <if test="teamId != null">
                `team_id`,
            </if>
            <if test="name != null">
                `name`,
            </if>
            <if test="content != null">
                `content`,
            </if>
            <if test="startTime != null">
                `start_time`,
            </if>
            <if test="budget != null">
                `budget`,
            </if>
            <if test="avgBudget != null">
                `avg_budget`,
            </if>
            <if test="amount != null">
                `amount`,
            </if>
            <if test="avgFee != null">
                `avg_fee`,
            </if>
            <if test="endTime != null">
                `end_time`
            </if>
        </trim>
        )
        values (
        <trim suffixOverrides=",">
            <if test="teamId != null">
                #{teamId},
            </if>
            <if test="name != null">
                #{name},
            </if>
            <if test="content != null">
                #{content},
            </if>
            <if test="startTime != null">
                #{startTime},
            </if>
            <if test="budget != null">
                #{budget},
            </if>
            <if test="avgBudget != null">
                #{avgBudget},
            </if>
            <if test="amount != null">
                #{amount},
            </if>
            <if test="avgFee != null">
                #{avgFee},
            </if>
            <if test="endTime != null">
                #{endTime}
            </if>
        </trim>
        )
    </insert>

    <update id="update" parameterType="com.model.Activity">
        update activity
        <set>
            <if test="teamId != null">
                `team_id` = #{teamId} ,
            </if>
            <if test="name != null">
                `name` = #{name} ,
            </if>
            <if test="content != null">
                `content` = #{content} ,
            </if>
            <if test="startTime != null">
                `start_time` = #{startTime} ,
            </if>
            <if test="budget != null">
                `budget` = #{budget} ,
            </if>
            <if test="avgBudget != null">
                `avg_budget` = #{avgBudget} ,
            </if>
            <if test="amount != null">
                `amount` = #{amount} ,
            </if>
            <if test="avgFee != null">
                `avg_fee` = #{avgFee} ,
            </if>
            <if test="endTime != null">
                `end_time` = #{endTime}
            </if>
        </set>
        where id = #{id}
    </update>

    <update id="endActivity" parameterType="com.model.Activity">
        <!--计算平均消费-->

        update activity a
        set `avg_fee` = (amount / (Select count(0) + 1 from activity_user s where s.activity_id = a.id) ) ,
            end_time = CURRENT_TIMESTAMP
        where id = #{id};

        <!--减团费-->
        update team a
        set team_fee = team_fee - (select amount from activity where id = #{id})
        where a.id = (select team_id  from activity where id = #{id} );
    </update>

    <delete id="deleteById">
        delete
        from activity
        where id = #{id}
    </delete>
</mapper>